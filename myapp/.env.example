# ============================================================
# MindArc — Frontend Environment Variables (myapp/.env)
# Copy this file to .env and fill in your real values.
# NEVER commit .env — it is gitignored.
# ============================================================

# ------------------------------------------------------------
# Google Gemini AI API Keys (used by the FastAPI backend)
# Get from: https://aistudio.google.com/app/apikey
# ------------------------------------------------------------
GOOGLE_API_KEY=your_gemini_api_key_here
GOOGLE_API_KEY_2=your_gemini_api_key_2_here

# ------------------------------------------------------------
# Supabase (used for any Supabase-integrated features)
# Get from: https://supabase.com/dashboard/project/_/settings/api
# ------------------------------------------------------------
EXPO_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ------------------------------------------------------------
# Backend API URL
# For local dev: http://[IP_ADDRESS]  (your Wi-Fi IP)
# For production: https://your-backend.onrender.com/
# ------------------------------------------------------------
EXPO_PUBLIC_API_URL=http://[IP_ADDRESS]

# ------------------------------------------------------------
# Google Sign-In OAuth Client ID
# Get from: https://console.cloud.google.com/apis/credentials
# Must be the WEB client ID (not Android or iOS)
# ------------------------------------------------------------
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your_google_web_client_id.apps.googleusercontent.com

# ------------------------------------------------------------
# Firebase Client Configuration (used by standard JS SDK)
# Get from: Firebase Console -> Project Settings -> General -> Web App
# ------------------------------------------------------------
EXPO_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key_here
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project-id.firebasestorage.app
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id_here
EXPO_PUBLIC_FIREBASE_APP_ID=your_firebase_app_id_here
